{
  "name": "PostgreSQL Curso",
  "workspaceFolder": "/workspaces/postgrespace",
  "dockerComposeFile": "docker-compose.yml",
  "service": "workspace",

  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    }
  },

  "postCreateCommand": "sudo apt-get update -qq && sudo apt-get install -y postgresql-client && pip install psycopg2-binary --quiet",

  "remoteEnv": {
    "PGHOST": "postgres",
    "PGUSER": "postgres",
    "PGPASSWORD": "1234",
    "PGDATABASE": "postgres"
  },

  "runServices": [
    "postgres",
    "pgadmin"
  ],

  "forwardPorts": [
    5432,
    5050
  ],

  "portsAttributes": {
    "5050": {
      "label": "pgAdmin",
      "onAutoForward": "openBrowser"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode-remote.remote-containers",
        "github.codespaces",
        "anthropic.claude-code"
      ]
    }
  }
}